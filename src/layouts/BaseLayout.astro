---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../lib/site";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  /** If set, the image is preloaded as LCP candidate. Use on pages with a hero image. */
  preloadImage?: string;
  /** Canonical path, no domain. Defaults to Astro.url.pathname. */
  canonicalPath?: string;
  /** Override og:type. Default: website. Use "event" on registration pages. */
  ogType?: string;
  /** Extra JSON-LD objects to embed in <head> alongside the default Organization schema. */
  structuredData?: unknown[];
}

const {
  title,
  description = SITE.description,
  ogImage = SITE.ogImage,
  preloadImage,
  canonicalPath,
  ogType = "website",
  structuredData = [],
} = Astro.props;

const pageTitle = title ? `${title} — ${SITE.name}` : `${SITE.name} — ${SITE.tagline}`;
const canonical = new URL(canonicalPath ?? Astro.url.pathname, SITE.url).toString();

// Block indexing when served from a non-canonical host (e.g. preview deployments
// on *.pages.dev). Prevents duplicate-content issues with the primary domain.
const currentHost = Astro.url.hostname;
const canonicalHost = new URL(SITE.url).hostname;
const isNonCanonicalHost = currentHost !== canonicalHost && currentHost !== "localhost";

// Auto-generate a BreadcrumbList schema from the path (skipped on the homepage).
const pathname = canonicalPath ?? Astro.url.pathname;
const segments = pathname.split("/").filter(Boolean);
const breadcrumbSchema =
  segments.length === 0
    ? null
    : {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: [
          {
            "@type": "ListItem",
            position: 1,
            name: "Home",
            item: SITE.url,
          },
          ...segments.map((seg, i) => ({
            "@type": "ListItem",
            position: i + 2,
            name: (title && i === segments.length - 1)
              ? title
              : seg
                  .split("-")
                  .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
                  .join(" "),
            item: new URL(
              "/" + segments.slice(0, i + 1).join("/") + "/",
              SITE.url,
            ).toString(),
          })),
        ],
      };

// Organization + WebSite schemas are emitted on every page.
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "SportsOrganization",
  name: SITE.name,
  url: SITE.url,
  logo: new URL("/icon-512.png", SITE.url).toString(),
  email: SITE.contact.email,
  sameAs: [SITE.photoArchive.url],
  location: {
    "@type": "Place",
    name: SITE.venue.name,
    address: {
      "@type": "PostalAddress",
      streetAddress: SITE.venue.address,
      addressLocality: SITE.venue.city,
      addressRegion: SITE.venue.region,
      postalCode: SITE.venue.postalCode,
      addressCountry: SITE.venue.country,
    },
  },
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
  inLanguage: SITE.locale,
};

const allSchemas = [
  orgSchema,
  websiteSchema,
  ...(breadcrumbSchema ? [breadcrumbSchema] : []),
  ...structuredData,
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0a0b0d" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {isNonCanonicalHost && (
      <meta name="robots" content="noindex, nofollow" />
    )}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, SITE.url).toString()} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={SITE.locale} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, SITE.url).toString()} />

    <!-- Preload: display font only on desktop (media query prevents mobile download contention with hero image) -->
    <link
      rel="preload"
      href="/fonts/BarlowCondensed-700.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
      media="(min-width: 1024px)"
    />

    {preloadImage && (
      <link
        rel="preload"
        fetchpriority="high"
        as="image"
        href={preloadImage}
      />
    )}

    <!-- Favicons — SVG preferred, PNG fallbacks, ICO for legacy -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Structured data -->
    {allSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>

  <body class="min-h-dvh text-[var(--color-text)] antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-[var(--color-nv)] focus:text-[var(--color-bg)] focus:px-4 focus:py-2 focus:font-semibold"
    >
      Skip to content
    </a>

    <Header />

    <main id="main" class="relative">
      <slot />
    </main>

    <Footer />
  </body>
</html>
