---
import BaseLayout from "../layouts/BaseLayout.astro";
import Picture from "../components/Picture.astro";
import MosaicCycler from "../components/MosaicCycler.astro";
import { photos } from "../lib/gallery";
import { SITE } from "../lib/site";

// Use largest-available photos for the cycler so the hero rotation is sharp
const cyclerPhotos = photos.filter((p) => p.widths.includes(1600) || p.widths.includes(1024));

// Facade-loaded YouTube videos. Iframes are injected only on user click to
// preserve PageSpeed scores — see <script> below.
const videos = [
  {
    id: "BUKDUWkRX1k",
    title: "NVG Competitor POV — Oct 2024",
    blurb: "15-minute competitor POV walking through course, stages, and format in detail.",
  },
  {
    id: "7aXI5hBeWd8",
    title: "NV Division — Participant Interview",
    blurb: "A Twilight NV competitor on stages, course, gear, and where things went sideways.",
  },
  {
    id: "SMX2E39as3Y",
    title: "White Light Division — Event Documentary",
    blurb: "Documentary from a WL participant/RO — from home, to the venue, through the event.",
  },
];
---

<BaseLayout
  title="Media"
  description="Video and photography from past Twilight Biathlon events in Pawnee, Oklahoma. Night vision, white light, and the run in between."
>
  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <p class="section-label">// Media</p>
    <h1
      class="mt-3 font-[family-name:var(--font-display)] text-5xl font-bold uppercase sm:text-6xl"
    >
      Night captured.
    </h1>
    <p class="mt-6 max-w-2xl text-[var(--color-text-muted)]">
      Video and {photos.length} curated frames from past events. Click any
      thumbnail to jump the cycler. Full photo archive on {SITE.photoArchive.host}.
    </p>

    {/* Videos */}
    <div id="videos" class="mt-16 scroll-mt-24">
      <p class="section-label">// Videos</p>
      <h2 class="mt-2 font-[family-name:var(--font-display)] text-2xl font-semibold uppercase sm:text-3xl">
        Watch the event.
      </h2>
      <p class="mt-2 max-w-2xl text-sm text-[var(--color-text-muted)]">
        Competitor-produced videos covering the format, the course, and the experience.
      </p>

      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {videos.map((v) => (
          <figure class="video-card">
            <button
              type="button"
              class="video-facade group"
              data-video-id={v.id}
              data-video-title={v.title}
              aria-label={`Play video: ${v.title}`}
            >
              <img
                src={`https://i.ytimg.com/vi/${v.id}/maxresdefault.jpg`}
                data-fallback={`https://i.ytimg.com/vi/${v.id}/hqdefault.jpg`}
                onload="if(this.naturalWidth<200&&this.dataset.fallback){this.src=this.dataset.fallback;delete this.dataset.fallback;}"
                onerror="if(this.dataset.fallback){this.src=this.dataset.fallback;delete this.dataset.fallback;}"
                alt=""
                loading="lazy"
                decoding="async"
                width="1280"
                height="720"
                class="video-thumb"
              />
              <span class="video-play" aria-hidden="true">
                <svg viewBox="0 0 68 48" xmlns="http://www.w3.org/2000/svg">
                  <path class="video-play-bg" d="M66.52 7.74a8.2 8.2 0 0 0-5.78-5.79C55.58.5 34 .5 34 .5s-21.58 0-26.74 1.45a8.2 8.2 0 0 0-5.78 5.79A85.6 85.6 0 0 0 .5 24a85.6 85.6 0 0 0 .98 16.26 8.2 8.2 0 0 0 5.78 5.79C12.42 47.5 34 47.5 34 47.5s21.58 0 26.74-1.45a8.2 8.2 0 0 0 5.78-5.79A85.6 85.6 0 0 0 67.5 24a85.6 85.6 0 0 0-.98-16.26Z" />
                  <path class="video-play-tri" d="M27 34V14l18 10-18 10Z" />
                </svg>
              </span>
            </button>
            <figcaption class="video-caption">
              <p class="font-[family-name:var(--font-mono)] text-xs uppercase tracking-[0.2em] text-[var(--color-nv)]">
                {v.title}
              </p>
              <p class="mt-2 text-sm text-[var(--color-text)]/90 leading-relaxed">
                {v.blurb}
              </p>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>

    {/* Hero cycler */}
    <div class="mt-16">
      <p class="section-label">// Gallery</p>
      <h2 class="mt-2 font-[family-name:var(--font-display)] text-2xl font-semibold uppercase sm:text-3xl">
        Photography.
      </h2>
      <div class="mt-8">
        <MosaicCycler photos={cyclerPhotos} intervalMs={5000} />
      </div>
    </div>

    {/* Archive CTA */}
    <div class="mt-10 flex flex-col gap-4 border border-[var(--color-hairline)] bg-[var(--color-surface)]/40 p-6 sm:flex-row sm:items-center sm:justify-between sm:p-8">
      <div>
        <p class="section-label">// Full Archive</p>
        <h2 class="mt-2 font-[family-name:var(--font-display)] text-2xl font-semibold uppercase sm:text-3xl">
          Every frame, every match.
        </h2>
        <p class="mt-2 max-w-xl text-sm text-[var(--color-text-muted)]">
          Hundreds of additional photos from every Twilight Biathlon event,
          hosted on {SITE.photoArchive.host}. Free to view, browse, and download.
        </p>
      </div>
      <a
        href={SITE.photoArchive.url}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary shrink-0 text-sm"
      >
        Open {SITE.photoArchive.host} →
      </a>
    </div>

    {/* Thumbnail grid */}
    <div class="mt-16">
      <p class="section-label">// Thumbnails</p>
      <h2 class="mt-2 font-[family-name:var(--font-display)] text-2xl font-semibold uppercase">
        Curated set
      </h2>
      <p class="mt-2 max-w-2xl text-sm text-[var(--color-text-muted)]">
        Click any photo to load it in the cycler above.
      </p>

      <div
        class="mt-8 grid grid-cols-2 gap-2 sm:grid-cols-3 lg:grid-cols-4"
        data-gallery-thumbs
      >
        {photos.map((p) => (
          <button
            type="button"
            data-photo-id={p.id}
            class="group relative aspect-[3/2] overflow-hidden bg-[var(--color-surface)] focus:outline-none focus:ring-2 focus:ring-[var(--color-nv)] focus:ring-offset-2 focus:ring-offset-[var(--color-bg)]"
            aria-label={`Load photo ${p.id} into cycler`}
          >
            <Picture
              id={p.id}
              widths={p.widths}
              dir="gallery"
              alt={p.caption ?? "Twilight Biathlon photograph"}
              sizes="(min-width: 1024px) 25vw, (min-width: 640px) 33vw, 50vw"
              class="h-full w-full transition-transform duration-500 ease-out group-hover:scale-[1.03]"
            />
            <div
              class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[var(--color-bg)]/40 via-transparent to-transparent opacity-0 transition-opacity group-hover:opacity-100"
              aria-hidden="true"
            />
          </button>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .video-card {
    display: flex;
    flex-direction: column;
    margin: 0;
  }

  .video-facade {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border: 1px solid var(--color-hairline);
    background: var(--color-surface);
    cursor: pointer;
    padding: 0;
  }
  .video-facade:focus-visible {
    outline: 2px solid var(--color-nv);
    outline-offset: 2px;
  }

  .video-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease-out, filter 0.2s ease-out;
  }
  .video-facade:hover .video-thumb,
  .video-facade:focus-visible .video-thumb {
    transform: scale(1.03);
    filter: brightness(0.85);
  }

  .video-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }
  .video-play svg {
    width: 68px;
    height: 48px;
    filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.5));
    transition: transform 0.2s ease-out;
  }
  .video-facade:hover .video-play svg,
  .video-facade:focus-visible .video-play svg {
    transform: scale(1.08);
  }
  .video-play-bg {
    fill: rgba(10, 11, 13, 0.75);
    transition: fill 0.2s ease-out;
  }
  .video-facade:hover .video-play-bg,
  .video-facade:focus-visible .video-play-bg {
    fill: #00e474;
  }
  .video-play-tri {
    fill: #00e474;
    transition: fill 0.2s ease-out;
  }
  .video-facade:hover .video-play-tri,
  .video-facade:focus-visible .video-play-tri {
    fill: #0a0b0d;
  }

  .video-caption {
    padding-top: 0.75rem;
  }

  /* Iframe slot once activated — replaces the facade */
  .video-iframe {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 1px solid var(--color-hairline);
    display: block;
  }
</style>

<script>
  // Thumbnail clicks → cycler
  document.addEventListener("DOMContentLoaded", () => {
    const cycler = document.querySelector<HTMLElement & { jumpToId?: (id: string) => void }>(
      "[data-mosaic-cycler]",
    );
    if (cycler) {
      document.querySelectorAll<HTMLButtonElement>("[data-photo-id]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const id = btn.dataset.photoId;
          if (id && cycler.jumpToId) {
            cycler.jumpToId(id);
            cycler.scrollIntoView({ behavior: "smooth", block: "start" });
          }
        });
      });
    }

    // Video facade → iframe on click
    document
      .querySelectorAll<HTMLButtonElement>(".video-facade[data-video-id]")
      .forEach((facade) => {
        facade.addEventListener("click", () => {
          const vid = facade.dataset.videoId;
          const title = facade.dataset.videoTitle ?? "";
          if (!vid) return;
          const iframe = document.createElement("iframe");
          iframe.className = "video-iframe";
          iframe.src = `https://www.youtube-nocookie.com/embed/${vid}?autoplay=1&rel=0`;
          iframe.title = title;
          iframe.setAttribute("frameborder", "0");
          iframe.setAttribute(
            "allow",
            "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share",
          );
          iframe.setAttribute("referrerpolicy", "strict-origin-when-cross-origin");
          iframe.setAttribute("allowfullscreen", "");
          facade.replaceWith(iframe);
        });
      });
  });
</script>
