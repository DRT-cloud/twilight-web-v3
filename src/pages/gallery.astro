---
import BaseLayout from "../layouts/BaseLayout.astro";
import Picture from "../components/Picture.astro";
import { photos } from "../lib/gallery";
---

<BaseLayout
  title="Gallery"
  description="Photography from past Twilight Biathlon events in Pawnee, Oklahoma. Night vision, white light, and the run in between."
>
  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <p class="section-label">// Gallery</p>
    <h1
      class="mt-3 font-[family-name:var(--font-display)] text-5xl font-bold uppercase sm:text-6xl"
    >
      Night captured.
    </h1>
    <p class="mt-6 max-w-2xl text-[var(--color-text-muted)]">
      {photos.length} frames from past events. AVIF with WebP and JPEG
      fallbacks, lazy-loaded below the fold.
    </p>

    <div
      class="mt-12 grid grid-cols-2 gap-2 sm:grid-cols-3 lg:grid-cols-4"
    >
      {photos.map((p) => (
        <figure class="group relative aspect-[3/2] overflow-hidden bg-[var(--color-surface)]">
          <Picture
            id={p.id}
            widths={p.widths}
            dir="gallery"
            alt={p.caption ?? "Twilight Biathlon photograph"}
            sizes="(min-width: 1024px) 25vw, (min-width: 640px) 33vw, 50vw"
            class="h-full w-full transition-transform duration-500 ease-out group-hover:scale-[1.03]"
          />
          <div
            class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[var(--color-bg)]/40 via-transparent to-transparent opacity-0 transition-opacity group-hover:opacity-100"
            aria-hidden="true"
          />
        </figure>
      ))}
    </div>
  </section>
</BaseLayout>
