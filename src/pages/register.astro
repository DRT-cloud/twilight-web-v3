---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import EventCard from "../components/EventCard.astro";
import PageHeader from "../components/PageHeader.astro";
import { SITE } from "../lib/site";

const all = await getCollection("events");
const now = new Date();
const upcoming = all
  .filter((e) => e.data.endDate >= now)
  .sort((a, b) => a.data.startDate.getTime() - b.data.startDate.getTime());

const eventSchemas = upcoming.map((e) => ({
  "@context": "https://schema.org",
  "@type": "SportsEvent",
  name: `Twilight Biathlon — ${e.data.title}`,
  description: SITE.description,
  startDate: e.data.startDate.toISOString().slice(0, 10),
  endDate: e.data.endDate.toISOString().slice(0, 10),
  eventStatus: "https://schema.org/EventScheduled",
  eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
  location: {
    "@type": "Place",
    name: SITE.venue.name,
    address: {
      "@type": "PostalAddress",
      streetAddress: SITE.venue.address,
      addressLocality: SITE.venue.city,
      addressRegion: SITE.venue.region,
      postalCode: SITE.venue.postalCode,
      addressCountry: SITE.venue.country,
    },
  },
  organizer: {
    "@type": "Organization",
    name: SITE.name,
    url: SITE.url,
  },
  image: new URL("/images/og-default.jpg", SITE.url).toString(),
  offers: e.data.registrationUrl
    ? {
        "@type": "Offer",
        url: e.data.registrationUrl,
        price: String(e.data.entryFee),
        priceCurrency: "USD",
        availability:
          e.data.status === "registration-open"
            ? "https://schema.org/InStock"
            : "https://schema.org/PreOrder",
        validFrom: e.data.registrationOpens.toISOString().slice(0, 10),
      }
    : undefined,
}));
---

<BaseLayout
  title="Register"
  description="Register for the next Twilight Biathlon. PractiScore + PayPal. Registration is not complete until PayPal payment is received."
  ogType="event"
  structuredData={eventSchemas}
>
  <PageHeader
    eyebrow="// Register"
    title="Secure your spot."
  />

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <p class="max-w-2xl text-[var(--color-text-muted)]">
      Registration is handled through PractiScore. Payment is handled separately
      through PayPal.
      <strong class="text-[var(--color-text)]">
        Your registration is not complete until PayPal payment is received.
      </strong>
    </p>

    <div class="mt-12 grid gap-6 lg:grid-cols-2">
      {upcoming.map((event) => <EventCard event={event} />)}
    </div>

    <div
      class="mt-16 border border-[var(--color-hairline)] bg-[var(--color-surface)] p-8"
    >
      <p class="section-label text-[var(--color-nv)]">// How It Works</p>
      <ol class="mt-4 space-y-4 text-[var(--color-text)]/90">
        <li>
          <span class="font-[family-name:var(--font-mono)] text-[var(--color-nv)]">01</span>
          Register on PractiScore for the division(s) you want. Max 2 divisions per competitor.
        </li>
        <li>
          <span class="font-[family-name:var(--font-mono)] text-[var(--color-nv)]">02</span>
          Watch for a confirmation email with PayPal payment instructions.
        </li>
        <li>
          <span class="font-[family-name:var(--font-mono)] text-[var(--color-nv)]">03</span>
          Complete PayPal payment ($100 first division, $50 second). Your slot is now confirmed.
        </li>
      </ol>
    </div>
  </section>
</BaseLayout>
