---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import StatsStrip from "../components/StatsStrip.astro";
import EventCard from "../components/EventCard.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Differentiators from "../components/Differentiators.astro";
import Countdown from "../components/Countdown.astro";
import QuickLinks from "../components/QuickLinks.astro";
import UpdatesSignup from "../components/UpdatesSignup.astro";

// Load all events, sort by date, pick the next upcoming one for countdown + hero CTA.
const all = await getCollection("events");
const sorted = all.sort(
  (a, b) => a.data.startDate.getTime() - b.data.startDate.getTime(),
);
const now = new Date();
const upcoming = sorted.filter((e) => e.data.endDate >= now);
const nextEvent = upcoming[0] ?? sorted[sorted.length - 1]!;

// Construct ISO target for countdown (Friday first release).
// Astro frontmatter executes at build time; format as ISO.
const countdownTarget = nextEvent.data.startDate.toISOString();

// Hero variants live in /public/images/hero/ as hero-twilight-{768,1280,1920}w.{avif,webp,jpg}
// Preload the 1280w AVIF — covers typical laptop viewports without over-fetching on mobile.
const heroPreload = "/images/hero/hero-twilight-1280w.avif";
---

<BaseLayout
  title=""
  preloadImage={heroPreload}
  canonicalPath="/"
>
  <Hero
    nextEventStart={nextEvent.data.startDate}
    nextEventEnd={nextEvent.data.endDate}
    registrationUrl={nextEvent.data.registrationUrl}
  />

  <StatsStrip />

  <!-- Upcoming events -->
  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between gap-4">
      <div>
        <p class="section-label">// Upcoming Events</p>
        <h2
          class="mt-3 font-[family-name:var(--font-display)] text-4xl font-bold uppercase sm:text-5xl"
        >
          Two nights. Four divisions.
        </h2>
      </div>
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-2">
      {upcoming.slice(0, 2).map((event) => <EventCard event={event} />)}
    </div>
  </section>

  <Countdown target={countdownTarget} label="First Release" />

  <HowItWorks />

  <Differentiators />

  <QuickLinks />

  <UpdatesSignup />
</BaseLayout>
