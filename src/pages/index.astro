---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import StatsStrip from "../components/StatsStrip.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Differentiators from "../components/Differentiators.astro";
import Countdown from "../components/Countdown.astro";
import QuickLinks from "../components/QuickLinks.astro";
import UpdatesSignup from "../components/UpdatesSignup.astro";
import { SITE } from "../lib/site";

// Load all events, sort by date, pick the next upcoming one for countdown + hero CTA.

const all = await getCollection("events");
const sorted = all.sort(
  (a, b) => a.data.startDate.getTime() - b.data.startDate.getTime(),
);
const now = new Date();
const upcoming = sorted.filter((e) => e.data.endDate >= now);
const nextEvent = upcoming[0] ?? sorted[sorted.length - 1]!;

// Parse the check-in start time from the event's checkinWindow string
// (e.g. "7:00–8:00 PM each night" → 7:00 PM on startDate).
// All events are in Central Time; Oklahoma observes DST, so May = CDT (UTC-5),
// October = CDT (still before first-Sunday-November DST end). Use UTC-5.
function parseCheckinTarget(startDate: Date, window: string): string {
  const m = window.match(/^(\d{1,2}):(\d{2})\s*[–\-]?.*?(AM|PM)/i);
  let hour = 19;
  let minute = 0;
  if (m) {
    hour = parseInt(m[1], 10);
    minute = parseInt(m[2], 10);
    if (/PM/i.test(m[3]) && hour < 12) hour += 12;
    if (/AM/i.test(m[3]) && hour === 12) hour = 0;
  }
  const y = startDate.getUTCFullYear();
  const mo = String(startDate.getUTCMonth() + 1).padStart(2, "0");
  const d = String(startDate.getUTCDate()).padStart(2, "0");
  const hh = String(hour).padStart(2, "0");
  const mm = String(minute).padStart(2, "0");
  // Central Daylight Time offset (UTC-5) — both Twilight events are inside DST.
  return `${y}-${mo}-${d}T${hh}:${mm}:00-05:00`;
}

const countdownTarget = parseCheckinTarget(
  nextEvent.data.startDate,
  nextEvent.data.checkinWindow,
);

// Hero variants live in /public/images/hero/ as hero-twilight-{768,1280,1920}w.{avif,webp,jpg}
// Preload the 1280w AVIF — covers typical laptop viewports without over-fetching on mobile.
const heroPreload = "/images/hero/hero-twilight-1280w.avif";

// SportsEvent JSON-LD for each upcoming event surfaces event cards in Google results.
const eventSchemas = upcoming.map((e) => ({
  "@context": "https://schema.org",
  "@type": "SportsEvent",
  name: `Twilight Biathlon — ${e.data.title}`,
  description: SITE.description,
  startDate: e.data.startDate.toISOString().slice(0, 10),
  endDate: e.data.endDate.toISOString().slice(0, 10),
  eventStatus: "https://schema.org/EventScheduled",
  eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
  location: {
    "@type": "Place",
    name: SITE.venue.name,
    address: {
      "@type": "PostalAddress",
      streetAddress: SITE.venue.address,
      addressLocality: SITE.venue.city,
      addressRegion: SITE.venue.region,
      postalCode: SITE.venue.postalCode,
      addressCountry: SITE.venue.country,
    },
  },
  organizer: {
    "@type": "Organization",
    name: SITE.name,
    url: SITE.url,
  },
  image: new URL("/images/og-default.jpg", SITE.url).toString(),
  offers: e.data.registrationUrl
    ? {
        "@type": "Offer",
        url: e.data.registrationUrl,
        price: String(e.data.entryFee),
        priceCurrency: "USD",
        availability:
          e.data.status === "registration-open"
            ? "https://schema.org/InStock"
            : "https://schema.org/PreOrder",
        validFrom: e.data.registrationOpens.toISOString().slice(0, 10),
      }
    : undefined,
}));
---

<BaseLayout
  title=""
  preloadImage={heroPreload}
  canonicalPath="/"
  structuredData={eventSchemas}
>
  <Hero />

  <Countdown target={countdownTarget} label="Countdown to Next Twilight" />

  <StatsStrip />

  <HowItWorks />

  <Differentiators />

  <QuickLinks />

  <UpdatesSignup />
</BaseLayout>
