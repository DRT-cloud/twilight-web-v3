---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../lib/site";
---

<BaseLayout
  title="Contact"
  description="Contact the Twilight Biathlon organizers for volunteer, sponsor, or event inquiries."
>
  <section class="mx-auto max-w-2xl px-4 py-20 sm:px-6 lg:px-8">
    <p class="section-label">// Contact</p>
    <h1
      class="mt-3 font-[family-name:var(--font-display)] text-5xl font-bold uppercase sm:text-6xl"
    >
      Reach out.
    </h1>

    <div class="mt-12 space-y-8">
      <div class="border border-[var(--color-hairline)] bg-[var(--color-surface)] p-6">
        <p class="section-label text-[var(--color-nv)]">// Email</p>
        <a
          href={`mailto:${SITE.contact.email}`}
          class="mt-3 block font-[family-name:var(--font-mono)] text-xl hover:text-[var(--color-nv)]"
        >
          {SITE.contact.email}
        </a>
        <p class="mt-2 text-sm text-[var(--color-text-muted)]">
          Registration, logistics, volunteer, sponsor, general inquiries.
        </p>
      </div>

      <div class="border border-[var(--color-hairline)] p-6">
        <p class="section-label">// Venue</p>
        <p class="mt-3 text-lg">{SITE.venue.name}</p>
        <p class="text-[var(--color-text-muted)]">
          {SITE.venue.city}, {SITE.venue.state}
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
