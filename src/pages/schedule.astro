---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatEventRange } from "../lib/format";

const all = await getCollection("events");
const sorted = all.sort(
  (a, b) => a.data.startDate.getTime() - b.data.startDate.getTime(),
);
---

<BaseLayout
  title="Schedule"
  description="Per-event check-in, shooters meeting, and first-release times for upcoming Twilight Biathlon events."
>
  <section class="mx-auto max-w-4xl px-4 py-20 sm:px-6 lg:px-8">
    <p class="section-label">// Schedule</p>
    <h1
      class="mt-3 font-[family-name:var(--font-display)] text-5xl font-bold uppercase sm:text-6xl"
    >
      Event-night timing.
    </h1>

    <div class="mt-12 space-y-10">
      {
        sorted.map((event) => (
          <article class="border border-[var(--color-hairline)] bg-[var(--color-surface)] p-8">
            <p class="section-label text-[var(--color-nv)]">
              {event.data.season === "spring" ? "Spring" : "Fall"}{" "}
              {event.data.startDate.getUTCFullYear()}
            </p>
            <h2 class="mt-2 font-[family-name:var(--font-display)] text-3xl font-bold uppercase">
              {formatEventRange(event.data.startDate, event.data.endDate)}
            </h2>

            <dl class="mt-6 grid gap-x-6 gap-y-3 sm:grid-cols-2">
              {event.data.gatesOpen && (
                <div class="flex justify-between border-b border-[var(--color-hairline)] py-2">
                  <dt class="text-[var(--color-text-muted)]">Gates open</dt>
                  <dd class="font-[family-name:var(--font-mono)]">
                    {event.data.gatesOpen}
                  </dd>
                </div>
              )}
              <div class="flex justify-between border-b border-[var(--color-hairline)] py-2">
                <dt class="text-[var(--color-text-muted)]">Check-in</dt>
                <dd class="font-[family-name:var(--font-mono)]">
                  {event.data.checkinWindow}
                </dd>
              </div>
              <div class="flex justify-between border-b border-[var(--color-hairline)] py-2">
                <dt class="text-[var(--color-text-muted)]">Shooters meeting</dt>
                <dd class="font-[family-name:var(--font-mono)]">
                  {event.data.shootersMeeting}
                </dd>
              </div>
              <div class="flex justify-between border-b border-[var(--color-hairline)] py-2">
                <dt class="text-[var(--color-text-muted)]">First release</dt>
                <dd class="font-[family-name:var(--font-mono)]">
                  {event.data.firstRelease}
                </dd>
              </div>
            </dl>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
