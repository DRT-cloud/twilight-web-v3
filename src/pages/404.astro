---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not Found" description="Page not found.">
  <section class="mx-auto max-w-3xl px-4 py-32 text-center sm:px-6 lg:px-8">
    <p class="font-[family-name:var(--font-mono)] text-sm text-[var(--color-nv)]">
      // 404
    </p>
    <h1 class="mt-4 font-[family-name:var(--font-display)] text-6xl font-bold uppercase sm:text-8xl">
      Out of contact.
    </h1>
    <p class="mt-6 text-[var(--color-text-muted)]">
      That page isn't on the course map.
    </p>
    <a href="/" class="btn-primary mt-10 text-sm">Return to base →</a>
  </section>
</BaseLayout>
