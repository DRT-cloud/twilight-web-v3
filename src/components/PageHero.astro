---
// PageHero — parallax image banner for non-home pages.
// The section height is derived from the photo's own aspect ratio so the
// complete image is visible (no top/bottom crop). Height is capped on very
// tall/portrait photos so they don't dominate the viewport.
// Reuses the same parallax pattern as <Hero> (disables on reduced-motion,
// coarse pointers, and narrow viewports). Uses Astro's Image component so
// photos are served as optimized AVIF/WebP.

import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  image: ImageMetadata;
  alt?: string;
  eyebrow: string;        // e.g. "// About"
  title: string;          // e.g. "The original nighttime run-and-gun biathlon."
  objectPosition?: string; // defaults to center
}

const { image, alt = "", eyebrow, title, objectPosition = "center" } = Astro.props;

// Photo's natural aspect ratio (width / height). Used to compute hero height
// so the full image is shown without cropping. Fallback to 3/2 if metadata
// is missing for any reason.
const ratio = image.width && image.height ? image.width / image.height : 1.5;
---

<section
  class="page-hero relative isolate overflow-hidden flex items-end"
  style={`aspect-ratio: ${ratio}; max-height: 78vh; min-height: 360px;`}
>
  <div class="page-hero-parallax absolute inset-0 will-change-transform" data-page-parallax>
    <Image
      src={image}
      alt={alt}
      widths={[768, 1280, 1920]}
      sizes="100vw"
      format="avif"
      quality={78}
      loading="eager"
      decoding="async"
      class="page-hero-img absolute inset-0 h-[110%] w-full object-cover"
      style={`object-position: ${objectPosition};`}
    />
  </div>

  {/* Bottom fade into body bg + subtle top scrim for header legibility */}
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-[var(--color-bg)] via-[var(--color-bg)]/60 to-transparent"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-24 bg-gradient-to-b from-[var(--color-bg)]/55 to-transparent"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto w-full max-w-7xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8 lg:py-20">
    <p class="section-label text-[var(--color-nv)] text-shadow-sm">{eyebrow}</p>
    <h1
      class="mt-3 font-[family-name:var(--font-display)] text-4xl font-bold uppercase leading-[1.05] tracking-tight text-shadow sm:text-5xl lg:text-6xl"
    >
      {title}
    </h1>
  </div>
</section>

<style>
  .page-hero-img {
    opacity: 1;
    filter: brightness(1.38) contrast(1.02) saturate(1.08);
  }

  @media (prefers-reduced-motion: reduce) {
    .page-hero-parallax {
      transform: none !important;
    }
  }
</style>

<script>
  // Per-page parallax — same pattern as the home hero but scoped to
  // [data-page-parallax]. Disabled on touch/narrow viewports.
  (() => {
    const layer = document.querySelector<HTMLElement>("[data-page-parallax]");
    if (!layer) return;

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const coarse = window.matchMedia("(pointer: coarse)").matches;
    const narrow = window.matchMedia("(max-width: 768px)").matches;
    if (reduce || coarse || narrow) return;

    let ticking = false;
    const SPEED = 0.25;

    const update = () => {
      const rect = layer.getBoundingClientRect();
      const sectionHeight = rect.height;
      const scrolled = Math.max(0, -rect.top);
      const offset = Math.min(scrolled * SPEED, sectionHeight * 0.08);
      layer.style.transform = `translate3d(0, ${offset}px, 0)`;
      ticking = false;
    };

    const onScroll = () => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    };

    update();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
  })();
</script>
