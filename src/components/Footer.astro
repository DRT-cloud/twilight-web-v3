---
import { SITE } from "../lib/site";

const year = new Date().getFullYear();
---

<footer
  class="mt-24 border-t border-[var(--color-hairline)] bg-[var(--color-bg)]"
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-10 md:grid-cols-3">
      <div>
        <p class="section-label">Event</p>
        <p class="mt-3 font-[family-name:var(--font-display)] text-2xl font-bold uppercase">
          Twilight Biathlon
        </p>
        <p class="mt-2 max-w-sm text-sm text-[var(--color-text-muted)]">
          Held at {SITE.venue.name}, {SITE.venue.city}, {SITE.venue.state}.
        </p>
      </div>

      <div>
        <p class="section-label">Site</p>
        <ul class="mt-3 space-y-1 text-sm">
          {
            [...SITE.nav, ...SITE.footerNav].map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-[var(--color-text-muted)] hover:text-[var(--color-text)]"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <p class="section-label">Contact</p>
        <p class="mt-3 text-sm">
          <a
            href={`mailto:${SITE.contact.email}`}
            class="text-[var(--color-text-muted)] hover:text-[var(--color-nv)]"
          >
            {SITE.contact.email}
          </a>
        </p>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col gap-2 border-t border-[var(--color-hairline)] pt-6 text-xs text-[var(--color-text-muted)] sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} Twilight Biathlon. Running since 2018.</p>
      <p class="font-[family-name:var(--font-mono)]">PAWNEE · OK</p>
    </div>
  </div>
</footer>
