---
import { formatEventRange, formatCurrency, formatShortDate } from "../lib/format";
import type { CollectionEntry } from "astro:content";

interface Props {
  event: CollectionEntry<"events">;
}

const { event } = Astro.props;
const d = event.data;
---

<article
  class="group relative flex flex-col justify-between border border-[var(--color-hairline)] bg-[var(--color-surface)] p-8 transition-colors hover:border-[var(--color-nv)]/50"
>
  <div>
    <div class="flex items-start justify-between gap-4">
      <div>
        <p class="section-label">
          {d.season === "spring" ? "Spring" : "Fall"} Event
        </p>
        <p
          class="mt-2 font-[family-name:var(--font-display)] text-4xl font-bold uppercase leading-none"
        >
          {formatEventRange(d.startDate, d.endDate)}
        </p>
      </div>
      {
        d.status === "registration-open" ? (
          <span class="shrink-0 rounded-sm border border-[var(--color-nv)] bg-[var(--color-nv)]/10 px-2 py-1 font-[family-name:var(--font-mono)] text-xs font-semibold uppercase tracking-wider text-[var(--color-nv)]">
            Registration Open
          </span>
        ) : d.status === "upcoming" ? (
          <span class="shrink-0 rounded-sm border border-[var(--color-hairline)] bg-[var(--color-surface)] px-2 py-1 font-[family-name:var(--font-mono)] text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
            Upcoming
          </span>
        ) : null
      }
    </div>

    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      <div class="border-l-2 border-[var(--color-nv)]/60 pl-4">
        <p class="section-label text-[var(--color-nv)]">
          Fri {formatShortDate(d.startDate)} · NV
        </p>
        <p class="mt-1 text-sm text-[var(--color-text)]">
          {d.fridayDivisions.join(" / ")}
        </p>
        <p class="mt-1 text-xs text-[var(--color-text-muted)]">
          Night Vision Only
        </p>
      </div>

      <div class="border-l-2 border-[var(--color-wl)]/60 pl-4">
        <p class="section-label" style="color: var(--color-wl)">
          Sat {formatShortDate(d.endDate)} · WL
        </p>
        <p class="mt-1 text-sm text-[var(--color-text)]">
          {d.saturdayDivisions.join(" / ")}
        </p>
        <p class="mt-1 text-xs text-[var(--color-text-muted)]">White Light</p>
      </div>
    </div>

    <dl class="mt-8 grid gap-x-6 gap-y-2 text-sm sm:grid-cols-2">
      {d.squaddingOpens && (
        <div class="flex justify-between gap-2 border-b border-[var(--color-hairline)] py-2 sm:col-span-2">
          <dt class="text-[var(--color-text-muted)]">Squadding opens</dt>
          <dd class="text-right font-[family-name:var(--font-mono)]">{d.squaddingOpens}</dd>
        </div>
      )}
      {d.gatesOpen && (
        <div class="flex justify-between gap-2 border-b border-[var(--color-hairline)] py-2">
          <dt class="text-[var(--color-text-muted)]">Gates open</dt>
          <dd class="text-right font-[family-name:var(--font-mono)]">{d.gatesOpen}</dd>
        </div>
      )}
      <div class="flex justify-between gap-2 border-b border-[var(--color-hairline)] py-2">
        <dt class="text-[var(--color-text-muted)]">Check-in</dt>
        <dd class="text-right font-[family-name:var(--font-mono)]">{d.checkinWindow}</dd>
      </div>
      <div class="flex justify-between gap-2 border-b border-[var(--color-hairline)] py-2">
        <dt class="text-[var(--color-text-muted)]">Shooters meeting</dt>
        <dd class="text-right font-[family-name:var(--font-mono)]">{d.shootersMeeting}</dd>
      </div>
      <div class="flex justify-between gap-2 border-b border-[var(--color-hairline)] py-2">
        <dt class="text-[var(--color-text-muted)]">First release</dt>
        <dd class="text-right font-[family-name:var(--font-mono)]">{d.firstRelease}</dd>
      </div>
      <div class="flex justify-between gap-2 border-b border-[var(--color-hairline)] py-2 sm:col-span-2">
        <dt class="text-[var(--color-text-muted)]">Entry fee</dt>
        <dd class="text-right font-[family-name:var(--font-mono)]">
          {formatCurrency(d.entryFee)} · {formatCurrency(d.secondDivisionFee)} second division
        </dd>
      </div>
    </dl>
  </div>

  <div class="mt-8 flex flex-col gap-3 sm:flex-row">
    <a
      href={d.registrationUrl ?? "/register"}
      target={d.registrationUrl ? "_blank" : undefined}
      rel={d.registrationUrl ? "noopener noreferrer" : undefined}
      class:list={[
        "flex-1 text-sm",
        d.registrationUrl ? "btn-primary" : "btn-ghost",
      ]}
    >
      {d.registrationUrl ? "Register →" : "Details"}
    </a>
  </div>
</article>
