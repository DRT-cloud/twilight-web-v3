---
// PageHeader — simple eyebrow + title block for non-home pages.
// No background photo; the body-level camo pattern shows through via a
// semi-transparent scrim that keeps the header text legible.

interface Props {
  eyebrow: string;
  title: string;
}

const { eyebrow, title } = Astro.props;
---

<section class="relative isolate">
  {/* Soft bg scrim so header text stays readable on top of the camo */}
  <div
    class="pointer-events-none absolute inset-0 bg-gradient-to-b from-[var(--color-bg)]/80 via-[var(--color-bg)]/55 to-transparent"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto w-full max-w-7xl px-4 pt-16 pb-10 sm:px-6 sm:pt-24 sm:pb-12 lg:px-8 lg:pt-28 lg:pb-14">
    <p class="section-label text-[var(--color-nv)] text-shadow-sm">{eyebrow}</p>
    <h1
      class="mt-3 font-[family-name:var(--font-display)] text-4xl font-bold uppercase leading-[1.05] tracking-tight text-shadow sm:text-5xl lg:text-6xl"
    >
      {title}
    </h1>
  </div>
</section>
