---
import NewsletterForm from "./NewsletterForm.astro";
---

<section class="border-t border-[var(--color-hairline)]">
  <div class="mx-auto max-w-3xl px-4 py-20 sm:px-6 lg:px-8">
    <NewsletterForm
      variant="stacked"
      label="// Announcements"
      heading="Get updates and announcements."
      description="Be first to know when registration opens. NV-night reminders, weather calls, and event drops — never anything else."
    />
  </div>
</section>
