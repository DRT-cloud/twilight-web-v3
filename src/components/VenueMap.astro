---
/**
 * VenueMap — interactive Leaflet map of the venue.
 *
 * Data: /src/content/venue.geojson (imported at build time).
 * Basemap: Esri World Imagery satellite (no API key). Optional topo toggle.
 * Filters: category chips (gates, parking, bays, POI) toggle layers on/off.
 * UX: click marker/polygon → slide-in side panel with details.
 */
import venueJson from "../content/venue.geojson?raw";
const venue = JSON.parse(venueJson);

const featureCount = venue.features.length;
---

{/* Leaflet assets — loaded only on pages that mount this component */}
<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>

<div
  class="venue-map-wrap relative overflow-hidden border border-[var(--color-hairline)] bg-[var(--color-surface)]"
  data-venue-map
  data-geojson={JSON.stringify(venue)}
>
  {/* Filter chips */}
  <div class="flex flex-wrap items-center gap-2 border-b border-[var(--color-hairline)] bg-[var(--color-bg)] p-3 sm:p-4">
    <span class="section-label mr-2 text-xs">// Filters</span>
    <button
      type="button"
      class="venue-filter active"
      data-filter="gate"
      aria-pressed="true"
    >
      <span class="dot bg-[#4ade80]"></span>
      Gates
    </button>
    <button
      type="button"
      class="venue-filter active"
      data-filter="parking"
      aria-pressed="true"
    >
      <span class="dot bg-[#60a5fa]"></span>
      Parking
    </button>
    <button
      type="button"
      class="venue-filter active"
      data-filter="bay"
      aria-pressed="true"
    >
      <span class="dot bg-[#f87171]"></span>
      Bays
    </button>
    <button
      type="button"
      class="venue-filter active"
      data-filter="poi"
      aria-pressed="true"
    >
      <span class="dot bg-[#fbbf24]"></span>
      Points of Interest
    </button>

    <div class="ml-auto flex items-center gap-2">
      <button
        type="button"
        class="venue-basemap active"
        data-basemap="sat"
        aria-pressed="true"
      >
        Satellite
      </button>
      <button
        type="button"
        class="venue-basemap"
        data-basemap="topo"
        aria-pressed="false"
      >
        Topo
      </button>
    </div>
  </div>

  {/* Map + detail panel row */}
  <div class="relative grid grid-cols-1 md:grid-cols-[1fr_320px]">
    <div
      class="venue-map aspect-[4/3] w-full md:aspect-auto md:h-[600px]"
      aria-label={`Interactive venue map with ${featureCount} points of interest`}
    ></div>

    {/* Detail panel (desktop: sidebar; mobile: below map) */}
    <aside
      class="venue-detail border-t border-[var(--color-hairline)] bg-[var(--color-bg)] p-4 sm:p-6 md:border-l md:border-t-0"
      aria-live="polite"
    >
      <p class="section-label">// Detail</p>
      <div class="venue-detail-empty mt-3 text-sm text-[var(--color-text-muted)]">
        Click any gate, parking area, or shooting bay on the map for details.
      </div>
      <div class="venue-detail-body mt-3 hidden">
        <h3
          class="venue-detail-name font-[family-name:var(--font-display)] text-xl font-semibold uppercase"
        ></h3>
        <p class="venue-detail-category mt-1 text-xs uppercase tracking-widest text-[var(--color-nv)]"></p>
        <p class="venue-detail-description mt-4 text-sm text-[var(--color-text)]"></p>
        <p class="venue-detail-notes mt-2 text-sm text-[var(--color-text-muted)]"></p>
        <dl class="venue-detail-coords mt-4 space-y-1 font-[family-name:var(--font-mono)] text-xs text-[var(--color-text-muted)]"></dl>
        <a
          class="venue-detail-directions btn-ghost mt-4 inline-flex text-xs"
          href="#"
          target="_blank"
          rel="noopener noreferrer"
        >
          Open in Google Maps →
        </a>
      </div>
    </aside>
  </div>
</div>

<style>
  /* Filter chips */
  .venue-filter,
  .venue-basemap {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--color-hairline);
    background: var(--color-surface);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: background-color 120ms, color 120ms, border-color 120ms;
    cursor: pointer;
  }
  .venue-filter:hover,
  .venue-basemap:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
  }
  .venue-filter.active {
    color: var(--color-text);
    border-color: var(--color-nv);
    background: color-mix(in srgb, var(--color-nv) 12%, var(--color-surface));
  }
  .venue-basemap.active {
    color: var(--color-text);
    border-color: var(--color-nv);
    background: color-mix(in srgb, var(--color-nv) 12%, var(--color-surface));
  }
  .venue-filter .dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 9999px;
  }

  /* Leaflet container */
  .venue-map {
    background: #0a0a0a;
  }
  /* Override default Leaflet popup styling to match site */
  :global(.leaflet-container) {
    font-family: inherit;
    background: #0a0a0a !important;
  }
  :global(.leaflet-popup-content-wrapper),
  :global(.leaflet-popup-tip) {
    background: var(--color-bg) !important;
    color: var(--color-text) !important;
    border: 1px solid var(--color-hairline);
    border-radius: 2px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
  }
  :global(.leaflet-popup-content) {
    margin: 12px 14px !important;
    font-size: 0.8rem;
  }
  :global(.leaflet-control-zoom a) {
    background: var(--color-surface) !important;
    color: var(--color-text) !important;
    border-color: var(--color-hairline) !important;
  }
  :global(.leaflet-control-zoom a:hover) {
    background: var(--color-bg) !important;
  }
  :global(.leaflet-control-attribution) {
    background: rgba(10, 10, 10, 0.8) !important;
    color: var(--color-text-muted) !important;
    font-size: 10px !important;
  }
  :global(.leaflet-control-attribution a) {
    color: var(--color-text) !important;
  }

  /* Custom marker container (SVG injected via JS) */
  :global(.venue-marker) {
    background: transparent !important;
    border: none !important;
  }
</style>

<script>
  // @ts-ignore — resolved at build time by Vite/Astro
  import L from "leaflet";

  type FeatureProps = {
    name: string;
    category: "gate" | "parking" | "bay" | "poi";
    description: string;
    notes: string;
  };

  const CATEGORY_COLORS: Record<string, string> = {
    gate: "#4ade80",     // green
    parking: "#60a5fa",  // blue
    bay: "#f87171",      // red
    poi: "#fbbf24",      // amber
  };

  const CATEGORY_LABELS: Record<string, string> = {
    gate: "Gate",
    parking: "Parking",
    bay: "Shooting Bay",
    poi: "Point of Interest",
  };

  function markerIcon(color: string) {
    // Solid circle with ring + crosshair — tactical feel
    const svg = `
      <svg width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
        <circle cx="16" cy="16" r="13" fill="${color}" fill-opacity="0.18" stroke="${color}" stroke-width="1.5"/>
        <circle cx="16" cy="16" r="5" fill="${color}"/>
        <line x1="16" y1="3" x2="16" y2="9" stroke="${color}" stroke-width="1.5"/>
        <line x1="16" y1="23" x2="16" y2="29" stroke="${color}" stroke-width="1.5"/>
        <line x1="3" y1="16" x2="9" y2="16" stroke="${color}" stroke-width="1.5"/>
        <line x1="23" y1="16" x2="29" y2="16" stroke="${color}" stroke-width="1.5"/>
      </svg>`;
    return L.divIcon({
      html: svg,
      className: "venue-marker",
      iconSize: [32, 32],
      iconAnchor: [16, 16],
      popupAnchor: [0, -14],
    });
  }

  function initMap(root: HTMLElement) {
    const geojson = JSON.parse(root.dataset.geojson || "{}");
    if (!geojson.features || !geojson.features.length) return;

    const mapEl = root.querySelector(".venue-map") as HTMLElement;
    const detailEmpty = root.querySelector(".venue-detail-empty") as HTMLElement;
    const detailBody = root.querySelector(".venue-detail-body") as HTMLElement;
    const detailName = root.querySelector(".venue-detail-name") as HTMLElement;
    const detailCategory = root.querySelector(".venue-detail-category") as HTMLElement;
    const detailDescription = root.querySelector(".venue-detail-description") as HTMLElement;
    const detailNotes = root.querySelector(".venue-detail-notes") as HTMLElement;
    const detailCoords = root.querySelector(".venue-detail-coords") as HTMLElement;
    const detailDirections = root.querySelector(
      ".venue-detail-directions",
    ) as HTMLAnchorElement;

    // Compute bounds from all features
    const allCoords: [number, number][] = [];
    geojson.features.forEach((f: any) => {
      if (f.geometry.type === "Point") {
        allCoords.push([f.geometry.coordinates[1], f.geometry.coordinates[0]]);
      } else if (f.geometry.type === "Polygon") {
        f.geometry.coordinates[0].forEach((c: [number, number]) => {
          allCoords.push([c[1], c[0]]);
        });
      }
    });
    const bounds = L.latLngBounds(allCoords);

    const map = L.map(mapEl, {
      zoomControl: true,
      attributionControl: true,
      scrollWheelZoom: true,
    }).fitBounds(bounds, { padding: [24, 24] });

    // Basemaps
    const sat = L.tileLayer(
      "https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}",
      {
        maxZoom: 19,
        attribution:
          "Imagery © Esri, Maxar, Earthstar Geographics",
      },
    );
    const topo = L.tileLayer(
      "https://server.arcgisonline.com/ArcGIS/rest/services/World_Topo_Map/MapServer/tile/{z}/{y}/{x}",
      {
        maxZoom: 19,
        attribution: "Topo © Esri",
      },
    );
    sat.addTo(map);

    // Layer groups per category
    const layers: Record<string, L.LayerGroup> = {
      gate: L.layerGroup().addTo(map),
      parking: L.layerGroup().addTo(map),
      bay: L.layerGroup().addTo(map),
      poi: L.layerGroup().addTo(map),
    };

    function showDetail(props: FeatureProps, latlng: L.LatLng) {
      detailEmpty.classList.add("hidden");
      detailBody.classList.remove("hidden");
      detailName.textContent = props.name || "(unnamed)";
      detailCategory.textContent = CATEGORY_LABELS[props.category] ?? props.category;
      detailDescription.textContent = props.description || "";
      detailNotes.textContent = props.notes || "";
      detailNotes.style.display = props.notes ? "" : "none";

      detailCoords.innerHTML = `
        <div><span class="text-[var(--color-text)]">Lat:</span> ${latlng.lat.toFixed(6)}</div>
        <div><span class="text-[var(--color-text)]">Lng:</span> ${latlng.lng.toFixed(6)}</div>
      `;
      detailDirections.href = `https://www.google.com/maps/dir/?api=1&destination=${latlng.lat},${latlng.lng}`;
    }

    // Add features to their category layer
    geojson.features.forEach((f: any) => {
      const props: FeatureProps = f.properties;
      const cat = props.category ?? "poi";
      const color = CATEGORY_COLORS[cat] ?? "#fbbf24";
      const layer = layers[cat] ?? layers.poi;

      if (f.geometry.type === "Point") {
        const [lng, lat] = f.geometry.coordinates;
        const m = L.marker([lat, lng], { icon: markerIcon(color) });
        m.bindPopup(
          `<strong>${props.name}</strong><br><span style="color:${color};text-transform:uppercase;font-size:10px;letter-spacing:0.08em;">${CATEGORY_LABELS[cat]}</span>${props.description ? `<br>${props.description}` : ""}`,
        );
        m.on("click", () => showDetail(props, L.latLng(lat, lng)));
        m.addTo(layer);
      } else if (f.geometry.type === "Polygon") {
        const latlngs = f.geometry.coordinates[0].map(
          (c: [number, number]) => [c[1], c[0]] as [number, number],
        );
        const poly = L.polygon(latlngs, {
          color: color,
          weight: 2,
          opacity: 0.9,
          fillColor: color,
          fillOpacity: 0.25,
        });
        poly.bindPopup(
          `<strong>${props.name}</strong><br><span style="color:${color};text-transform:uppercase;font-size:10px;letter-spacing:0.08em;">${CATEGORY_LABELS[cat]}</span>${props.description ? `<br>${props.description}` : ""}`,
        );
        poly.on("click", (e) => {
          showDetail(props, (e as any).latlng ?? poly.getBounds().getCenter());
        });
        poly.addTo(layer);
      }
    });

    // Filter chips
    root.querySelectorAll<HTMLButtonElement>(".venue-filter").forEach((btn) => {
      btn.addEventListener("click", () => {
        const cat = btn.dataset.filter!;
        const active = btn.classList.toggle("active");
        btn.setAttribute("aria-pressed", String(active));
        if (active) {
          layers[cat]?.addTo(map);
        } else {
          map.removeLayer(layers[cat]);
        }
      });
    });

    // Basemap toggle
    root.querySelectorAll<HTMLButtonElement>(".venue-basemap").forEach((btn) => {
      btn.addEventListener("click", () => {
        const kind = btn.dataset.basemap!;
        root.querySelectorAll<HTMLButtonElement>(".venue-basemap").forEach((b) => {
          b.classList.remove("active");
          b.setAttribute("aria-pressed", "false");
        });
        btn.classList.add("active");
        btn.setAttribute("aria-pressed", "true");
        if (kind === "sat") {
          map.removeLayer(topo);
          sat.addTo(map);
        } else {
          map.removeLayer(sat);
          topo.addTo(map);
        }
      });
    });

    // Recompute size on window resize so the map fits the container
    window.addEventListener("resize", () => {
      map.invalidateSize();
    });
    setTimeout(() => map.invalidateSize(), 200);
  }

  document.querySelectorAll<HTMLElement>("[data-venue-map]").forEach(initMap);
</script>
